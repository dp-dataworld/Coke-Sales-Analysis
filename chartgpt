        "plt.figure(figsize=(12, 6))\n",
        "sns.lineplot(x='Review Date', y='Review Count', data=daily_reviews)\n",
        "plt.title('ChatGPT Review Trends Over Time (Daily)')\n",
        "plt.xlabel('Date')\n",
        "plt.ylabel('Number of Reviews')\n",
